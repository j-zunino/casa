{
  "name": "casa",
  "type": "module",
  "private": true,
  "version": "0.0.1",
  "workspaces": [
    "client",
    "server",
    "shared"
  ],
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "dev:client": "pnpm --filter client dev",
    "dev:server": "pnpm --filter server dev",
    "build": "pnpm -r build",
    "start": "pnpm -r start",
    "typecheck": "pnpm -r typecheck",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "db:generate": "pnpm --filter server exec prisma generate",
    "db:migrate": "pnpm --filter server exec prisma migrate dev",
    "db:deploy": "pnpm --filter server exec prisma migrate deploy",
    "db:studio": "pnpm --filter server exec prisma studio",
    "db:reset": "pnpm --filter server exec prisma migrate reset"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@tanstack/eslint-plugin-query": "^5.91.4",
    "eslint": "catalog:",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.26",
    "globals": "^16.5.0",
    "typescript": "catalog:",
    "typescript-eslint": "^8.55.0"
  }
}
