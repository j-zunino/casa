generator client {
    provider = "prisma-client"
    output   = "../src/generated/prisma"
}

datasource db {
    provider = "postgresql"
}

// Enums
enum Visibility {
    PUBLIC
    PRIVATE
    CUSTOM // Specific members
}

enum RecurrenceFrequency {
    DAILY
    WEEKLY
    MONTHLY
    YEARLY
}

enum InvitationStatus {
    active
    revoked
    expired
}

model User {
    id            String  @id
    name          String
    email         String
    emailVerified Boolean @default(false)
    image         String?

    sessions           Session[]
    accounts           Account[]
    members            Member[]
    invitations        Invitation[] @relation("InvitationInviter")
    revokedInvitations Invitation[] @relation("InvitationRevokedBy")
    todos              Todo[]    @relation("UserTodoCreated")
    updatedTodos       Todo[]    @relation("UserTodoUpdated")

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@unique([email])
    @@map("user")
}

model Session {
    id            String  @id
    ipAddress     String?
    token         String
    user          User    @relation(fields: [userId], references: [id], onDelete: Cascade)
    userId        String
    userAgent     String?
    activeHouseId String?

    expiresAt DateTime
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@unique([token])
    @@index([userId])
    @@map("session")
}

model Account {
    id           String  @id
    idToken      String?
    user         User    @relation(fields: [userId], references: [id], onDelete: Cascade)
    userId       String
    accountId    String
    providerId   String
    password     String?
    scope        String?
    accessToken  String?
    refreshToken String?

    accessTokenExpiresAt  DateTime?
    refreshTokenExpiresAt DateTime?
    createdAt             DateTime  @default(now())
    updatedAt             DateTime  @updatedAt

    @@index([userId])
    @@map("account")
}

model Verification {
    id         String @id
    identifier String
    value      String

    expiresAt DateTime
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@index([identifier])
    @@map("verification")
}

model House {
    id          String       @id
    name        String
    slug        String
    logo        String?
    metadata    String?
    members     Member[]
    invitations Invitation[]
    todos       Todo[]

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@unique([slug])
    @@map("house")
}

model Member {
    id      String @id
    user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)
    userId  String
    house   House  @relation(fields: [houseId], references: [id], onDelete: Cascade)
    houseId String
    role    String @default("member")

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@index([houseId])
    @@index([userId])
    @@map("member")
}

model Invitation {
    id        String           @id
    email     String?
    code      String?          @unique
    maxUses   Int?
    useCount  Int              @default(0)
    inviter     User             @relation("InvitationInviter", fields: [inviterId], references: [id], onDelete: Cascade)
    inviterId   String
    house       House            @relation(fields: [houseId], references: [id], onDelete: Cascade)
    houseId     String
    status      InvitationStatus @default(active)
    revokedAt   DateTime?
    revokedBy   User?            @relation("InvitationRevokedBy", fields: [revokedById], references: [id])
    revokedById String?

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@index([houseId])
    @@index([code])
    @@map("invitation")
}

model Todo {
    id          String     @id
    title       String
    description String?
    visibility  Visibility @default(PRIVATE)
    isCompleted Boolean    @default(false)
    house       House      @relation(fields: [houseId], references: [id], onDelete: Cascade)
    houseId     String
    createdBy   User   @relation("UserTodoCreated", fields: [createdById], references: [id])
    createdById String
    updatedBy   User?  @relation("UserTodoUpdated", fields: [updatedById], references: [id])
    updatedById String?

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@index([houseId])
    @@index([createdById])
    @@map("todo")
}
